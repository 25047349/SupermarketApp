<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Edit Product</title>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Supermarket App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/addProduct">Add new product</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow">
          <div class="card-header bg-secondary text-white">
            <h3 class="mb-0">Edit Product</h3>
          </div>
          <div class="card-body">

            <% if (product) { %>
            <form action="/editProduct/<%= product.productId %>" method="POST" enctype="multipart/form-data">

              <div class="mb-3">
                <label for="name" class="form-label">Product Name</label>
                <input type="text" class="form-control" id="name" name="name"
                  value="<%= product.productName %>" required>
              </div>

              <div class="mb-3">
                <label for="quantity" class="form-label">Quantity</label>
                <input type="number" class="form-control" id="quantity" name="quantity"
                  min="0" step="1" value="<%= product.quantity %>" required>
              </div>

              <div class="mb-3">
                <label for="price" class="form-label">Price ($)</label>
                <input type="number" class="form-control" id="price" name="price"
                  min="0" step="0.01" value="<%= product.price %>" required>
              </div>

              <div class="mb-4">
                <label class="form-label">Current Image</label><br>
                <% if (product.image) { %>
                  <img src="/images/<%= product.image %>" width="20%" class="mb-2"><br>
                <% } %>
                <input type="hidden" name="currentImage" value="<%= product.image %>">
                <label for="image" class="form-label mt-2">New Image (optional)</label>
                <input type="file" class="form-control" id="image" name="image" accept="image/*">
              </div>

              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success">Update Product</button>
                <a href="/" class="btn btn-secondary">Cancel</a>
              </div>

            </form>
            <% } else { %>
              <p>Product not found.</p>
            <% } %>

          </div>
        </div>
      </div>
    </div>
  </div>

</body>
</html>